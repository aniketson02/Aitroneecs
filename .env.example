# ─── Supabase ────────────────────────────────────────────────
# Project Settings → API. Until these are set, the storefront serves
# the bundled seed catalog and stores no orders.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Keep this secret — server-only, used to write orders (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=

# ─── Razorpay ────────────────────────────────────────────────
# Dashboard → Settings → API Keys. Use TEST keys first (rzp_test_...).
# Until these are set, checkout runs a clearly-labelled demo flow.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
